{
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.dog-hub.shop" }],
      "destination": "https://dog-hub.shop/:path",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reminder",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/thankyou",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/index-articles",
      "schedule": "0 2 * * *"
    }
  ]
}
